{
	"$schema": "http://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
	"contentVersion": "1.0.0.0",
	"parameters": {
		"factoryName": {
			"type": "string",
			"metadata": "Data Factory name",
			"defaultValue": "safeadfdev"
		},
		"AzureBlobStorage1_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'AzureBlobStorage1'"
		},
		"ls_azblob_connectionString": {
			"type": "secureString",
			"metadata": "Secure string for 'connectionString' of 'ls_azblob'"
		},
		"AzureBlobStorage1_properties_connectVia_referenceName": {
			"type": "string",
			"defaultValue": "AzureManagedIRManaged"
		},
		"AzureBlobStorage1_properties_connectVia_type": {
			"type": "string",
			"defaultValue": "IntegrationRuntimeReference"
		},
		"AzureBlobStorage902_properties_privateLinkResourceId": {
			"type": "string",
			"defaultValue": "/subscriptions/49c9890d-08d4-4c03-b119-bd8e5af7b960/resourceGroups/safeDev/providers/Microsoft.Storage/storageAccounts/safeblobdev"
		},
		"AzureBlobStorage902_properties_groupId": {
			"type": "string",
			"defaultValue": "blob"
		},
		"containerUri": {
			"type": "string",
			"metadata": "URI to storage account containing linked ARM templates"
		},
		"containerSasToken": {
			"type": "string",
			"metadata": "Sas token to storage account containing linked ARM templates"
		}
	},
	"variables": {
		"factoryId": "[concat('Microsoft.DataFactory/factories/', parameters('factoryName'))]"
	},
	"resources": [
		{
			"name": "safeadfdev_ArmTemplate_0",
			"type": "Microsoft.Resources/deployments",
			"apiVersion": "2024-03-01",
			"properties": {
				"mode": "incremental",
				"templateLink": {
					"uri": "[concat(parameters('containerUri'), '/ArmTemplate_0.json', parameters('containerSasToken'))]",
					"contentVersion": "1.0.0.0"
				},
				"parameters": {
					"factoryName": {
						"value": "[parameters('factoryName')]"
					},
					"ls_azblob_connectionString": {
						"value": "[parameters('ls_azblob_connectionString')]"
					},
					"AzureBlobStorage1_connectionString": {
						"value": "[parameters('AzureBlobStorage1_connectionString')]"
					},
					"AzureBlobStorage902_properties_privateLinkResourceId": {
						"value": "[parameters('AzureBlobStorage902_properties_privateLinkResourceId')]"
					},
					"AzureBlobStorage902_properties_groupId": {
						"value": "[parameters('AzureBlobStorage902_properties_groupId')]"
					},
					"AzureBlobStorage1_properties_connectVia_referenceName": {
						"value": "[parameters('AzureBlobStorage1_properties_connectVia_referenceName')]"
					},
					"AzureBlobStorage1_properties_connectVia_type": {
						"value": "[parameters('AzureBlobStorage1_properties_connectVia_type')]"
					}
				}
			},
			"dependsOn": []
		}
	]
}